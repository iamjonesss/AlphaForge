{
  "name": "alphaforge",
  "displayName": "AlphaForge",
  "publisher": "Jonesdev",
  "description": "Precisa de um criador de template para projetos? A AlphaForge é a melhor opção!",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "icon": "assets/icon_alphaforge.png",
  "contributes": {
    "commands": [
      {
        "command": "alphaforge.helloWorld",
        "title": "Hello World"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "alphaforge-sidebar",
          "title": "AlphaForge",
          "icon": "assets/icon_alphaforge.png"
        }
      ]
    },
    "views": {
      "alphaforge-sidebar": [
        {
          "id": "alphaforge-view",
          "name": "Project Templates",
          "type": "webview",
          "icon": "assets/icon_alphaforge.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iamjonesss/AlphaForge.git"
  }
}